{
  "manifest_version": 3,
  "name": "Website Code Extractor",
  "version": "1.3",
  "description": "Extract a website's HTML, CSS, JS, and images, then download everything as a ZIP file.",
  "permissions": [
    "activeTab",
    "downloads",
    "scripting"
  ],
  "icons": {
    "64": "icons/icon64.png",
    "96": "icons/icon96.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "64": "icons/icon64.png",
      "96": "icons/icon96.png"
    }
  },
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ]
}
